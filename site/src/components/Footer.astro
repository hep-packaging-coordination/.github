---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-[var(--color-cf-border)] bg-[var(--color-cf-bg)] py-8 text-center text-sm text-[var(--color-cf-text-muted)]">
  <nav aria-label="Footer links" class="flex flex-wrap justify-center gap-x-6 gap-y-2">
    <a
      href="https://github.com/hep-packaging-coordination"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--color-cf-primary)]"
    >
      GitHub org
    </a>
    <a
      href="https://github.com/hep-packaging-coordination/.github/blob/main/profile/README.md"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--color-cf-primary)]"
    >
      Profile README
    </a>
    <a
      href="https://conda-forge.org"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--color-cf-primary)]"
    >
      conda-forge
    </a>
    <a
      href="https://github.com/hep-packaging-coordination/.github/issues"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--color-cf-primary)]"
    >
      Issues
    </a>
  </nav>
  <p class="mt-4">
    Data refreshed every 6 hours · Badges served live by
    <a
      href="https://shields.io"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--color-cf-primary)]"
    >shields.io</a
    >
  </p>
</footer>
